# Kimi Code CLI (kimi --print agent) — uses KIMI_API_KEY from .env
# Docs: https://www.kimi.com/code/docs/kimi-code-cli/configuration/environment-variables.html

# Kimi Code Plan (sk-kimi-... keys)
KIMI_API_KEY=your-sk-kimi-key
KIMI_BASE_URL=https://api.kimi.com/coding/v1
KIMI_CODING_AGENT=true

# Moonshot Developer API (sk-... keys from platform.moonshot.cn / .ai)
# KIMI_API_KEY=your-moonshot-key
# KIMI_BASE_URL=https://api.moonshot.cn/v1
# KIMI_CODING_AGENT=false
